generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                 String             @id @default(uuid())
  name               String
  slug               String             @unique
  status             String             @default("active")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  code               String             @unique
  sequence           Int
  tenantType         String             @default("NGO")
  description        String?
  country            String?
  website            String?
  registrationNumber String?
  logoUrl            String?
  completedSetup     Boolean            @default(false)
  stripeCustomerId     String?          @unique
  stripeSubscriptionId String?
  plan                 String           @default("FREE")
  planStatus           String           @default("active")
  trialEndsAt          DateTime?
  baseCurrency         String           @default("USD")
  notificationPrefs    Json?
  apiKeys            ApiKey[]
  ocrJobs  OcrJob[]
  bundleJobs BundleJob[]
  verificationCases VerificationCase[]
  trustSeals         TrustSeal[]
  engagementEvents   EngagementEvent[]
  auditLogs          AuditLog[]
  documents          Document[]
  expenses           Expense[]
  fundingSources     FundingSource[]
  projects           Project[]
  refreshTokens      RefreshToken[]
  roles              Role[]
  users              User[]
  userRoles          UserRole[]
  fundingAgreements  FundingAgreement[]
  donorInvites       DonorInvite[]
  workflowTasks      WorkflowTask[]
  budgets            Budget[]

  @@index([code])
  @@index([tenantType])
}

model TenantCounter {
  id         String @id @default(uuid())
  tenantType String
  year       String
  count      Int    @default(0)

  @@unique([tenantType, year])
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  name              String
  password          String
  tenantId          String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?
  preferredLanguage String         @default("en")
  apiKeys           ApiKey[]       @relation("ApiKeyCreator")
  auditLogs         AuditLog[]
  uploadedDocuments Document[]
  refreshTokens     RefreshToken[]
  tenant            Tenant         @relation(fields: [tenantId], references: [id])
  roles             UserRole[]
  donorInvites      DonorInvite[]

  @@index([tenantId])
}

model Role {
  id          String           @id @default(uuid())
  name        String
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  permissions RolePermission[]
  users       UserRole[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserPermissionCache {
  id          String   @id @default(uuid())
  userId      String
  tenantId    String
  permissions Json     @default("[]")
  updatedAt   DateTime @updatedAt

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
}

model ApiKey {
  id          String    @id @default(uuid())
  tenantId    String
  createdBy   String
  name        String
  prefix      String    @unique
  keyHash     String
  permissions String[]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  creator     User      @relation("ApiKeyCreator", fields: [createdBy], references: [id])
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  ocrJobs    OcrJob[]
  usageLogs  ApiUsageLog[]
  @@index([tenantId])
  @@index([createdBy])
}

model ApiUsageLog {
  id           String   @id @default(uuid())
  apiKeyId     String
  apiKey       ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  tenantId     String
  endpoint     String
  method       String   @default("POST")
  statusCode   Int
  responseTime Int      @default(0)
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([apiKeyId])
  @@index([tenantId])
  @@index([createdAt])
  @@index([endpoint])
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  tenantId   String
  tokenHash  String
  family     String
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?
  userAgent  String?
  ip         String?
  createdAt  DateTime  @default(now())
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([family])
  @@index([tokenHash])
}

model Webhook {
  id          String            @id @default(uuid())
  tenantId    String
  url         String
  secret      String
  events      String[]
  active      Boolean           @default(true)
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deliveries  WebhookDelivery[]

  @@index([tenantId])
  @@index([active])
}

model WebhookDelivery {
  id           String    @id @default(uuid())
  webhookId    String
  tenantId     String
  event        String
  payload      Json
  status       String    @default("pending")
  statusCode   Int?
  responseBody String?
  attempts     Int       @default(0)
  nextRetryAt  DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime  @default(now())
  webhook      Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([tenantId])
  @@index([status])
  @@index([nextRetryAt])
}

model UserRole {
  id       String @id @default(uuid())
  userId   String
  roleId   String
  tenantId String
  role     Role   @relation(fields: [roleId], references: [id])
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([userId, roleId])
  @@index([tenantId])
}

model Project {
  id             String           @id @default(uuid())
  name           String
  description    String?
  budget         Float?
  tenantId       String
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  status         String           @default("active")
  logframeGoal        String?
  logframePurpose     String?
  logframeAssumptions String?
  documents      Document[]
  expenses       Expense[]
  fundingSources FundingSource[]
  budgets        Budget[]
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  projectFunding ProjectFunding[]
  donorInvites   DonorInvite[]

  @@index([tenantId])
  @@index([createdAt])
}

// @deprecated — use FundingAgreement instead. Kept for backward compatibility.
model FundingSource {
  id          String    @id @default(uuid())
  name        String
  fundingType String
  amount      Float
  currency    String
  projectId   String
  tenantId    String
  donorOrgId  String?
  funderName  String?
  funderType  String?   @default("EXTERNAL")
  createdAt   DateTime  @default(now())
  expenses    Expense[]
  project     Project   @relation(fields: [projectId], references: [id])
  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([fundingType])
  @@index([donorOrgId])
}

model Expense {
  id                 String            @id @default(uuid())
  description        String
  amount             Float
  currency           String
  projectId          String
  fundingSourceId    String?
  fundingAgreementId String?
  budgetId           String?
  budgetLineId       String?
  tenantId           String
  approvalStatus     String            @default("pending_review")
  expenseType        String?           // CAPEX or OPEX
  expenditureType    String            @default("OPEX") // CAPEX or OPEX
  category           String?
  subCategory        String?
  vendor             String?
  receiptFileKey     String?
  receiptHash        String?
  receiptSealId      String?
  ocrAmount          Float?
  ocrVendor          String?
  ocrDate            String?
  amountMismatch     Boolean           @default(false)
  vendorMismatch     Boolean           @default(false)
  dateMismatch       Boolean           @default(false)
  mismatchNote       String?
  fraudRiskScore     Int?
  fraudRiskLevel     String?
  fraudSignals       Json?
  approvalNote       String?
  approvedBy         String?
  approvedAt         DateTime?
  voided         Boolean           @default(false)
  voidedAt       DateTime?
  voidedReason   String?
  voidedBy       String?
  createdAt          DateTime          @default(now())
  documents          Document[]
  fundingSource      FundingSource?    @relation(fields: [fundingSourceId], references: [id])
  fundingAgreement   FundingAgreement? @relation("ExpenseFundingAgreement", fields: [fundingAgreementId], references: [id])
  budget             Budget?           @relation("ExpenseBudget", fields: [budgetId], references: [id])
  budgetLine         BudgetLine?       @relation("ExpenseBudgetLine", fields: [budgetLineId], references: [id])
  project            Project           @relation(fields: [projectId], references: [id])
  tenant             Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([fundingSourceId])
  @@index([fundingAgreementId])
  @@index([budgetId])
  @@index([budgetLineId])
  @@index([createdAt])
  @@index([expenseType])
}

model Document {
  id                    String    @id @default(uuid())
  name                  String
  description           String?
  documentType          String?
  documentLevel         String    @default("project")
  category              String?
  expiryDate            DateTime?
  expiryAlertSent30     Boolean   @default(false)
  expiryAlertSent7      Boolean   @default(false)
  expiryAlertSent1      Boolean   @default(false)
  fileUrl               String
  fileType              String?
  fileSize              Int?
  sha256Hash            String?
  ocrFingerprint             String?
  isDuplicate                Boolean   @default(false)
  duplicateOfId              String?
  duplicateOfName            String?
  crossTenantDuplicate       Boolean   @default(false)
  pHash                      String?
  isVisualDuplicate          Boolean   @default(false)
  visualDuplicateOfId        String?
  visualDuplicateOfName      String?
  crossTenantVisualDuplicate Boolean   @default(false)
  duplicateConfidence        String?
  duplicateMethod            String?
  fraudRiskScore             Int?
  fraudRiskLevel             String?
  fraudSignals               Json?
  expenseId                  String?
  projectId             String?
  tenantId              String
  uploadedById          String?
  approvalStatus        String    @default("approved")
  uploadedAt            DateTime  @default(now())
  expense               Expense?  @relation(fields: [expenseId], references: [id])
  project               Project?  @relation(fields: [projectId], references: [id])
  tenant                Tenant    @relation(fields: [tenantId], references: [id])
  uploadedBy            User?     @relation(fields: [uploadedById], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([expenseId])
  @@index([uploadedById])
  @@index([sha256Hash])
  @@index([ocrFingerprint])
  @@index([pHash])
  @@index([expiryDate])
}

model AuditLog {
  id              String    @id @default(uuid())
  action          String
  entityType      String
  entityId        String
  userId          String?
  tenantId        String
  blockchainTx    String?
  createdAt       DateTime  @default(now())
  batchId         String?
  dataHash        String?
  ancheredAt      DateTime?
  anchorStatus    String?
  blockHash       String?
  blockNumber     Int?
  prevHash        String?
  timestampStatus String?   @default("pending")
  timestampToken  String?
  timestampedAt   DateTime?
  tsaUrl          String?
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  user            User?     @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([createdAt])
  @@index([userId])
  @@index([batchId])
  @@index([anchorStatus])
}

// ─── Phase 6.5: Donor & Funding Model ──────────────────────

model Donor {
  id                 String             @id @default(uuid())
  name               String
  organisationName   String?
  type               String             @default("FOUNDATION")
  email              String?
  country            String?
  website            String?
  registrationNumber String?
  logoUrl            String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  donorUsers         DonorUser[]
  fundingAgreements  FundingAgreement[]

  @@index([type])
  @@index([email])
}

model DonorUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  donorId      String
  firstName    String
  lastName     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  donor        Donor    @relation(fields: [donorId], references: [id])

  @@index([donorId])
}

model FundingAgreement {
  id             String              @id @default(uuid())
  donorId        String?
  tenantId       String
  budgetId       String?
  title          String
  type           String              @default("GRANT")
  totalAmount    Float
  currency       String              @default("USD")
  startDate      DateTime?
  endDate        DateTime?
  interestRate   Float?
  repayable      Boolean             @default(false)
  status         String              @default("DRAFT")
  notes          String?
  sourceType     String?             // Own Funds, Government Grant, etc.
  sourceSubType  String?             // Restricted Grant, Program Grant, etc.
  grantorName    String?
  grantRef       String?
  grantFrom      DateTime?
  grantTo        DateTime?
  restricted     Boolean             @default(false)
  capexBudget    Float               @default(0)
  opexBudget     Float               @default(0)
  donorOrgId     String?
  funderName     String?
  funderType     String?             @default("EXTERNAL") // PORTAL or EXTERNAL
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  donor          Donor?              @relation(fields: [donorId], references: [id])
  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  budget         Budget?             @relation("BudgetFunding", fields: [budgetId], references: [id])
  repayments     RepaymentSchedule[]
  projectFunding ProjectFunding[]
  expenses       Expense[]           @relation("ExpenseFundingAgreement")

  @@index([donorId])
  @@index([tenantId])
  @@index([budgetId])
  @@index([status])
  @@index([type])
  @@index([sourceType])
  @@index([donorOrgId])
  @@index([funderType])
}

model RepaymentSchedule {
  id                 String           @id @default(uuid())
  fundingAgreementId String
  dueDate            DateTime
  amount             Float
  status             String           @default("PENDING")
  paidAt             DateTime?
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  fundingAgreement   FundingAgreement @relation(fields: [fundingAgreementId], references: [id])

  @@index([fundingAgreementId])
  @@index([status])
  @@index([dueDate])
}

model DonorInvite {
  id              String   @id @default(uuid())
  token           String   @unique
  email           String
  invitedByUserId String
  inviteType      String   @default("NGO_INVITES_DONOR")
  tenantId        String
  projectId       String?
  status          String   @default("PENDING")
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  invitedBy       User     @relation(fields: [invitedByUserId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  project         Project? @relation(fields: [projectId], references: [id])

  @@index([token])
  @@index([tenantId])
  @@index([email])
  @@index([status])
}

model ProjectFunding {
  id                 String           @id @default(uuid())
  projectId          String
  fundingAgreementId String
  allocatedAmount    Float
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  project            Project          @relation(fields: [projectId], references: [id])
  fundingAgreement   FundingAgreement @relation(fields: [fundingAgreementId], references: [id])

  @@unique([projectId, fundingAgreementId])
  @@index([projectId])
  @@index([fundingAgreementId])
}

model WorkflowTask {
  id          String            @id @default(uuid())
  tenantId    String
  type        String
  status      String            @default("pending")
  title       String
  description String?
  assignedTo  String?
  submittedBy String
  entityId    String
  entityType  String
  comments    WorkflowComment[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  resolvedAt  DateTime?
  tenant      Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([entityId])
  @@index([assignedTo])
}

model WorkflowComment {
  id        String       @id @default(uuid())
  taskId    String
  userId    String
  comment   String
  createdAt DateTime     @default(now())
  task      WorkflowTask @relation(fields: [taskId], references: [id])

  @@index([taskId])
}

model VerificationCase {
  id               String      @id @default(uuid())
  tenantId         String
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  clientName       String
  clientEmail      String?
  caseType         String      @default("OTHER")
  status           String      @default("OPEN")
  shareToken       String      @unique @default(uuid())
  overallRiskScore Int?
  ocrJobs          OcrJob[]
  bundleJobs       BundleJob[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([caseType])
  @@index([shareToken])
  @@index([createdAt])
}

model OcrJob {
  id               String    @id @default(uuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apiKeyId         String?
  apiKey           ApiKey?   @relation(fields: [apiKeyId], references: [id])
  originalFilename String
  fileType         String
  fileSize         Int
  s3Key            String
  detectedLanguage String?
  status           String    @default("pending")
  rawText          String?   @db.Text
  confidence       Float?
  documentType     String?
  normalisedJson   Json?
  normalisedPdfS3  String?
  assessmentScore  Int?
  assessmentResult String?
  assessmentNotes  String?   @db.Text
  flags            Json?
  hashValue        String?
  ocrFingerprint   String?
  pHash            String?
  anchorTxHash     String?
  anchoredAt       DateTime?
  proofBundleS3    String?
  bundleJobId      String?
  bundleJob        BundleJob? @relation(fields: [bundleJobId], references: [id])
  caseId           String?
  verificationCase VerificationCase? @relation(fields: [caseId], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@index([bundleJobId])
  @@index([caseId])
  @@index([ocrFingerprint])
  @@index([pHash])
}

model BundleJob {
  id               String    @id @default(uuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  status           String    @default("pending")
  fileCount        Int       @default(0)
  completedCount   Int       @default(0)
  overallRiskScore Int?
  overallRiskLevel String?
  crossAnalysisJson Json?
  masterReportS3   String?
  bundleHash       String?
  anchorTxHash     String?
  anchoredAt       DateTime?
  ocrJobs          OcrJob[]
  caseId           String?
  verificationCase VerificationCase? @relation(fields: [caseId], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@index([caseId])
}

model TrustSeal {
  id               String    @id @default(uuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documentTitle    String
  documentType     String    @default("CERTIFICATE")
  issuedTo         String
  issuedToEmail    String?
  issuedBy         String
  metadata         Json?
  rawHash          String
  pageHashes       Json?
  s3Key            String?
  fileType         String?
  anchorTxHash     String?
  anchoredAt       DateTime?
  blockNumber      Int?
  qrCodeUrl        String?
  status           String    @default("issued")
  issuerReference  String?
  apiKeyId         String?
  ipAddress        String?
  anchorRetryCount Int       @default(0)
  anchorLastRetryAt DateTime?
  ocrFingerprint   String?
  fraudRiskScore   Int?
  fraudRiskLevel   String?
  fraudSignals     Json?
  sourceType       String?

  // OCR fields
  ocrRawText          String?   @db.Text
  ocrAmount           Float?
  ocrVendor           String?
  ocrDate             String?
  ocrConfidence       Float?
  ocrEngine           String?

  // Mismatch fields
  amountMismatch      Boolean   @default(false)
  vendorMismatch      Boolean   @default(false)
  dateMismatch        Boolean   @default(false)
  mismatchNote        String?

  // Duplicate detection fields
  isDuplicate         Boolean   @default(false)
  duplicateOfId       String?
  duplicateOfName     String?
  crossTenantDuplicate Boolean  @default(false)
  duplicateConfidence String?
  duplicateMethod     String?
  isVisualDuplicate   Boolean   @default(false)
  pHash               String?

  // Entity reference fields
  expenseId           String?
  documentId          String?
  caseId              String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([tenantId])
  @@index([rawHash])
  @@index([status])
  @@index([createdAt])
  @@index([ocrFingerprint])
  @@index([expenseId])
  @@index([documentId])
  @@index([caseId])
}

model EngagementEvent {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  eventType String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([eventType])
  @@index([createdAt])
}

// ─── Feature 1B: Budgeting ─────────────────────────────────

model Budget {
  id          String       @id @default(uuid())
  tenantId    String
  projectId   String?
  name        String
  periodFrom  DateTime
  periodTo    DateTime
  status      String       @default("DRAFT") // DRAFT, APPROVED, ACTIVE, CLOSED
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  project     Project?     @relation(fields: [projectId], references: [id])
  lines       BudgetLine[]
  fundingSources BudgetFundingSource[]
  fundingAgreements FundingAgreement[] @relation("BudgetFunding")
  expenses    Expense[]    @relation("ExpenseBudget")

  @@index([tenantId])
  @@index([projectId])
  @@index([status])
  @@index([periodFrom, periodTo])
}

model BudgetLine {
  id             String   @id @default(uuid())
  budgetId       String
  expenseType    String   // CAPEX or OPEX
  category       String
  subCategory    String?
  description    String?
  approvedAmount Float
  currency       String   @default("USD")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  budget         Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  expenses       Expense[] @relation("ExpenseBudgetLine")

  @@index([budgetId])
  @@index([expenseType])
}

model BudgetFundingSource {
  id                 String   @id @default(uuid())
  budgetId           String
  sourceType         String
  sourceSubType      String?
  donorName          String
  amount             Float
  currency           String   @default("USD")
  agreementFileKey   String?
  agreementHash      String?
  fundingAgreementId String?
  donorOrgId         String?
  funderName         String?
  funderType         String?  @default("EXTERNAL")
  createdAt          DateTime @default(now())
  budget             Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
  @@index([donorOrgId])
}
