generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id             String          @id @default(uuid())
  name           String
  slug           String          @unique
  status         String          @default("active")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  code           String          @unique
  sequence       Int
  tenantType     String          @default("NGO")
  apiKeys        ApiKey[]
  auditLogs      AuditLog[]
  documents      Document[]
  expenses       Expense[]
  fundingSources FundingSource[]
  projects       Project[]
  refreshTokens  RefreshToken[]
  roles          Role[]
  users          User[]
  userRoles      UserRole[]

  @@index([code])
  @@index([tenantType])
}

model TenantCounter {
  id         String @id @default(uuid())
  tenantType String
  year       String
  count      Int    @default(0)

  @@unique([tenantType, year])
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  name              String
  password          String
  tenantId          String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?
  apiKeys           ApiKey[]       @relation("ApiKeyCreator")
  auditLogs         AuditLog[]
  uploadedDocuments Document[]
  refreshTokens     RefreshToken[]
  tenant            Tenant         @relation(fields: [tenantId], references: [id])
  roles             UserRole[]

  @@index([tenantId])
}

model Role {
  id          String           @id @default(uuid())
  name        String
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  permissions RolePermission[]
  users       UserRole[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserPermissionCache {
  id          String   @id @default(uuid())
  userId      String
  tenantId    String
  permissions Json     @default("[]")
  updatedAt   DateTime @updatedAt

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
}

model ApiKey {
  id          String    @id @default(uuid())
  tenantId    String
  createdBy   String
  name        String
  prefix      String    @unique
  keyHash     String
  permissions String[]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  creator     User      @relation("ApiKeyCreator", fields: [createdBy], references: [id])
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([createdBy])
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  tenantId   String
  tokenHash  String
  family     String
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?
  userAgent  String?
  ip         String?
  createdAt  DateTime  @default(now())
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([family])
  @@index([tokenHash])
}

model Webhook {
  id          String            @id @default(uuid())
  tenantId    String
  url         String
  secret      String
  events      String[]
  active      Boolean           @default(true)
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deliveries  WebhookDelivery[]

  @@index([tenantId])
  @@index([active])
}

model WebhookDelivery {
  id           String    @id @default(uuid())
  webhookId    String
  tenantId     String
  event        String
  payload      Json
  status       String    @default("pending")
  statusCode   Int?
  responseBody String?
  attempts     Int       @default(0)
  nextRetryAt  DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime  @default(now())
  webhook      Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([tenantId])
  @@index([status])
  @@index([nextRetryAt])
}

model UserRole {
  id       String @id @default(uuid())
  userId   String
  roleId   String
  tenantId String
  role     Role   @relation(fields: [roleId], references: [id])
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([userId, roleId])
  @@index([tenantId])
}

model Project {
  id             String          @id @default(uuid())
  name           String
  description    String?
  budget         Float?
  tenantId       String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  status         String          @default("active")
  documents      Document[]
  expenses       Expense[]
  fundingSources FundingSource[]
  tenant         Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([createdAt])
}

model FundingSource {
  id          String    @id @default(uuid())
  name        String
  fundingType String
  amount      Float
  currency    String
  projectId   String
  tenantId    String
  createdAt   DateTime  @default(now())
  expenses    Expense[]
  project     Project   @relation(fields: [projectId], references: [id])
  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([fundingType])
}

model Expense {
  id              String        @id @default(uuid())
  description     String
  amount          Float
  currency        String
  projectId       String
  fundingSourceId String?
  tenantId        String
  createdAt       DateTime      @default(now())
  documents       Document[]
  fundingSource   FundingSource? @relation(fields: [fundingSourceId], references: [id])
  project         Project       @relation(fields: [projectId], references: [id])
  tenant          Tenant        @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([fundingSourceId])
  @@index([createdAt])
}

model Document {
  id            String   @id @default(uuid())
  name          String
  description   String?
  documentType  String?
  documentLevel String   @default("project")
  fileUrl       String
  fileType      String?
  fileSize      Int?
  sha256Hash    String?
  expenseId     String?
  projectId     String?
  tenantId      String
  uploadedById  String?
  uploadedAt    DateTime @default(now())
  expense       Expense? @relation(fields: [expenseId], references: [id])
  project       Project? @relation(fields: [projectId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  uploadedBy    User?    @relation(fields: [uploadedById], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([expenseId])
  @@index([uploadedById])
  @@index([sha256Hash])
}

model AuditLog {
  id              String    @id @default(uuid())
  action          String
  entityType      String
  entityId        String
  userId          String?
  tenantId        String
  blockchainTx    String?
  createdAt       DateTime  @default(now())
  batchId         String?
  dataHash        String?
  ancheredAt      DateTime?
  anchorStatus    String?
  blockHash       String?
  blockNumber     Int?
  prevHash        String?
  timestampStatus String?   @default("pending")
  timestampToken  String?
  timestampedAt   DateTime?
  tsaUrl          String?
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  user            User?     @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([createdAt])
  @@index([userId])
  @@index([batchId])
  @@index([anchorStatus])
}
