# Database
DATABASE_URL='postgresql://user:pass@host:5432/dbname?sslmode=require'
JWT_SECRET=
JWT_EXPIRES_IN="7d"

# Polygon Blockchain
RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
BLOCKCHAIN_PRIVATE_KEY=your-wallet-private-key
BLOCKCHAIN_ENABLED=true
POLYGON_RPC_PRIMARY=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_FALLBACK=https://rpc-amoy.polygon.technology
ANCHOR_WALLET_KEY=your-wallet-key
ANCHOR_CONFIRMATIONS=128
REORG_RECHECK_BLOCKS=256
ANCHOR_MAX_RETRIES=3

# AWS S3 (REQUIRED — images will NOT display without these)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=tulipglobal.org
S3_BUCKET=tulipglobal.org
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# SMTP
# SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=your-ses-smtp-user
# SMTP_PASS=your-ses-smtp-pass

# App
APP_URL=https://app.sealayer.io

# Stripe
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_STARTER_PRICE_ID=price_REPLACE_ME
STRIPE_PRO_PRICE_ID=price_REPLACE_ME
