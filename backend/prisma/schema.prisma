generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ApiKey {
  id          String        @id @default(uuid())
  tenantId    String
  createdBy   String
  name        String
  prefix      String        @unique
  keyHash     String
  permissions String[]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [createdBy], references: [id])
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apiUsageLogs ApiUsageLog[]
  ocrJobs     OcrJob[]

  @@index([createdBy])
  @@index([tenantId])
}

model ApiUsageLog {
  id           String   @id @default(uuid())
  apiKeyId     String
  tenantId     String
  endpoint     String
  method       String   @default("POST")
  statusCode   Int
  responseTime Int      @default(0)
  errorMessage String?
  createdAt    DateTime @default(now())
  apiKey       ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([createdAt])
  @@index([endpoint])
  @@index([tenantId])
}

model AuditLog {
  id              String    @id @default(uuid())
  action          String
  entityType      String
  entityId        String
  userId          String?
  tenantId        String
  blockchainTx    String?
  createdAt       DateTime  @default(now())
  batchId         String?
  dataHash        String?
  ancheredAt      DateTime?
  anchorStatus    String?
  blockHash       String?
  blockNumber     Int?
  prevHash        String?
  timestampStatus String?   @default("pending")
  timestampToken  String?
  timestampedAt   DateTime?
  tsaUrl          String?
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  user            User?     @relation(fields: [userId], references: [id])

  @@index([anchorStatus])
  @@index([batchId])
  @@index([createdAt])
  @@index([tenantId])
  @@index([userId])
}

model Budget {
  id                  String                @id @default(uuid())
  tenantId            String
  name                String
  periodFrom          DateTime
  periodTo            DateTime
  status              String                @default("DRAFT")
  notes               String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  projectId           String?
  project             Project?              @relation(fields: [projectId], references: [id])
  tenant              Tenant                @relation(fields: [tenantId], references: [id])
  fundingSources      BudgetFundingSource[]
  lines               BudgetLine[]
  expenses            Expense[]
  fundingAgreements   FundingAgreement[]

  @@index([periodFrom, periodTo])
  @@index([projectId])
  @@index([status])
  @@index([tenantId])
}

model BudgetAlert {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String
  donorOrgId String
  threshold  Int
  sentAt     DateTime? @default(now()) @db.Timestamp(6)

  @@unique([projectId, donorOrgId, threshold])
}

model BudgetFundingSource {
  id                 String             @id @default(uuid())
  budgetId           String
  sourceType         String
  sourceSubType      String?
  donorName          String
  amount             Float
  currency           String             @default("USD")
  agreementFileKey   String?
  agreementHash      String?
  createdAt          DateTime           @default(now())
  donorOrgId         String?
  funderType         String?            @default("EXTERNAL") @db.VarChar(20)
  funderName         String?
  fundingAgreementId String?
  budget             Budget             @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  donorOrganisation  DonorOrganisation? @relation(fields: [donorOrgId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([budgetId])
}

model BudgetLine {
  id             String    @id @default(uuid())
  budgetId       String
  expenseType    String
  category       String
  subCategory    String?
  description    String?
  approvedAmount Float
  currency       String    @default("USD")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
  budget         Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  expenses       Expense[]

  @@index([budgetId])
  @@index([expenseType])
}

model BundleJob {
  id                String            @id @default(uuid())
  tenantId          String
  name              String
  status            String            @default("pending")
  fileCount         Int               @default(0)
  completedCount    Int               @default(0)
  overallRiskScore  Int?
  overallRiskLevel  String?
  crossAnalysisJson Json?
  masterReportS3    String?
  bundleHash        String?
  anchorTxHash      String?
  anchoredAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  caseId            String?
  verificationCase  VerificationCase? @relation(fields: [caseId], references: [id])
  Tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ocrJobs           OcrJob[]

  @@index([caseId])
  @@index([createdAt])
  @@index([status])
  @@index([tenantId])
}

model CallSession {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String       @db.Uuid
  callerId       String
  callerType     String       @db.VarChar(10)
  callerName     String       @db.VarChar(100)
  receiverId     String?
  receiverType   String?      @db.VarChar(10)
  status         String       @default("RINGING") @db.VarChar(20)
  startedAt      DateTime?    @db.Timestamp(6)
  endedAt        DateTime?    @db.Timestamp(6)
  createdAt      DateTime?    @default(now()) @db.Timestamp(6)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Conversation {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String
  donorOrgId        String
  lastMessageAt     DateTime?         @db.Timestamp(6)
  createdAt         DateTime?         @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?         @default(now()) @db.Timestamp(6)
  callSessions      CallSession[]
  donorOrganisation DonorOrganisation @relation(fields: [donorOrgId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messages          Message[]

  @@unique([tenantId, donorOrgId])
  @@index([donorOrgId], map: "idx_conversation_donor")
  @@index([tenantId], map: "idx_conversation_tenant")
}

model Covenant {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  investmentId     String           @db.Uuid
  description      String
  metric           String?          @db.VarChar(100)
  threshold        String?          @db.VarChar(100)
  checkFrequency   String?          @default("MONTHLY") @db.VarChar(20)
  lastCheckedAt    DateTime?        @db.Timestamp(6)
  status           String           @default("OK") @db.VarChar(20)
  createdAt        DateTime?        @default(now()) @db.Timestamp(6)
  updatedAt        DateTime?        @default(now()) @db.Timestamp(6)
  impactInvestment ImpactInvestment @relation(fields: [investmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([investmentId], map: "idx_covenant_investment")
}

model DeliverableRequest {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId             String
  tenantId              String
  donorOrgId            String
  donorMemberId         String
  title                 String                  @db.VarChar(200)
  description           String?
  requestType           String                  @default("REPORT") @db.VarChar(40)
  deadline              DateTime                @db.Timestamp(6)
  status                String                  @default("OPEN") @db.VarChar(20)
  reworkNote            String?
  confirmedAt           DateTime?               @db.Timestamp(6)
  createdAt             DateTime?               @default(now()) @db.Timestamp(6)
  updatedAt             DateTime?               @default(now()) @db.Timestamp(6)
  attachments           String?
  deliverableSubmissions DeliverableSubmission[]

  @@index([projectId], map: "idx_deliverable_project")
  @@index([tenantId], map: "idx_deliverable_tenant")
  @@index([donorOrgId], map: "idx_delreq_donor")
  @@index([projectId], map: "idx_delreq_project")
}

model DeliverableSubmission {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId          String             @db.Uuid
  submittedBy        String
  note               String?
  documentIds        String[]           @default([])
  submittedAt        DateTime?          @default(now()) @db.Timestamp(6)
  version            Int                @default(1)
  deliverableRequest DeliverableRequest @relation(fields: [requestId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([requestId], map: "idx_delsub_request")
}

model DisbursementTranche {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fundingAgreementId String
  projectId          String
  tenantId           String
  trancheNumber      Int
  amount             Decimal          @db.Decimal
  currency           String           @default("USD") @db.VarChar(10)
  releaseConditions  String?
  plannedReleaseDate DateTime?        @db.Timestamp(6)
  actualReleaseDate  DateTime?        @db.Timestamp(6)
  utilisedAmount     Decimal?         @default(0) @db.Decimal
  status             String           @default("PENDING") @db.VarChar(20)
  conditionsMetAt    DateTime?        @db.Timestamp(6)
  conditionsMetBy    String?
  notes              String?
  createdAt          DateTime?        @default(now()) @db.Timestamp(6)
  updatedAt          DateTime?        @default(now()) @db.Timestamp(6)
  evidenceDocumentId String?
  conversionLocked   Boolean?         @default(false)
  fundingAgreement   FundingAgreement @relation(fields: [fundingAgreementId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([fundingAgreementId], map: "idx_tranche_agreement")
}

model Document {
  id                         String    @id @default(uuid())
  name                       String
  fileUrl                    String
  fileType                   String?
  projectId                  String?
  tenantId                   String
  uploadedById               String?
  uploadedAt                 DateTime  @default(now())
  description                String?
  documentLevel              String    @default("project")
  documentType               String?
  expenseId                  String?
  fileSize                   Int?
  sha256Hash                 String?
  category                   String?
  expiryAlertSent1           Boolean   @default(false)
  expiryAlertSent30          Boolean   @default(false)
  expiryAlertSent7           Boolean   @default(false)
  expiryDate                 DateTime?
  approvalStatus             String    @default("approved")
  crossTenantDuplicate       Boolean   @default(false)
  duplicateOfId              String?
  duplicateOfName            String?
  isDuplicate                Boolean   @default(false)
  ocrFingerprint             String?
  crossTenantVisualDuplicate Boolean   @default(false)
  isVisualDuplicate          Boolean   @default(false)
  pHash                      String?
  visualDuplicateOfId        String?
  visualDuplicateOfName      String?
  duplicateConfidence        String?
  duplicateMethod            String?
  fraudRiskScore             Int?
  fraudRiskLevel             String?
  fraudSignals               Json?
  expense                    Expense?  @relation(fields: [expenseId], references: [id])
  project                    Project?  @relation(fields: [projectId], references: [id])
  tenant                     Tenant    @relation(fields: [tenantId], references: [id])
  uploadedBy                 User?     @relation(fields: [uploadedById], references: [id])

  @@index([expenseId])
  @@index([expiryDate])
  @@index([ocrFingerprint])
  @@index([pHash])
  @@index([projectId])
  @@index([sha256Hash])
  @@index([tenantId])
  @@index([uploadedById])
}

model Donor {
  id                 String             @id @default(uuid())
  name               String
  organisationName   String?
  type               String             @default("FOUNDATION")
  email              String?
  country            String?
  website            String?
  registrationNumber String?
  logoUrl            String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime
  donorUsers         DonorUser[]
  fundingAgreements  FundingAgreement[]

  @@index([email])
  @@index([type])
}

model DonorInvite {
  id              String   @id @default(uuid())
  token           String   @unique
  email           String
  invitedByUserId String
  inviteType      String   @default("NGO_INVITES_DONOR")
  tenantId        String
  projectId       String?
  status          String   @default("PENDING")
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  user            User     @relation(fields: [invitedByUserId], references: [id])
  project         Project? @relation(fields: [projectId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([email])
  @@index([status])
  @@index([tenantId])
  @@index([token])
}

model DonorMember {
  id                String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  email             String             @unique
  name              String?
  passwordHash      String
  donorOrgId        String?
  preferredLanguage String?            @default("en")
  lastLoginAt       DateTime?          @db.Timestamp(6)
  createdAt         DateTime?          @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?          @default(now()) @db.Timestamp(6)
  themePreference   String?            @default("system") @db.VarChar(10)
  donorOrganisation DonorOrganisation? @relation(fields: [donorOrgId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  savedReports      SavedReport[]
  shareLinks        ShareLink[]
}

model DonorNotification {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  donorMemberId String
  donorOrgId    String
  alertType     String    @db.VarChar(60)
  title         String    @db.VarChar(200)
  body          String
  entityType    String?   @db.VarChar(40)
  entityId      String?
  projectId     String?
  isRead        Boolean   @default(false)
  readAt        DateTime? @db.Timestamp(6)
  emailSent     Boolean   @default(false)
  emailSentAt   DateTime? @db.Timestamp(6)
  createdAt     DateTime? @default(now()) @db.Timestamp(6)

  @@index([donorMemberId], map: "idx_notif_member")
  @@index([donorOrgId], map: "idx_notif_org")
  @@index([donorMemberId, isRead], map: "idx_notif_read")
}

model DonorNotificationPref {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  donorMemberId String
  alertType     String    @db.VarChar(60)
  emailEnabled  Boolean   @default(true)
  inAppEnabled  Boolean   @default(true)
  createdAt     DateTime? @default(now()) @db.Timestamp(6)
  updatedAt     DateTime? @default(now()) @db.Timestamp(6)

  @@unique([donorMemberId, alertType])
}

model DonorOrganisation {
  id                  String                @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                String
  type                String?               @default("FOUNDATION")
  country             String?
  website             String?
  createdAt           DateTime?             @default(now()) @db.Timestamp(6)
  updatedAt           DateTime?             @default(now()) @db.Timestamp(6)
  budgetFundingSources BudgetFundingSource[]
  conversations        Conversation[]
  donorMembers         DonorMember[]
  donorProjectAccesses DonorProjectAccess[]
  fundingAgreements    FundingAgreement[]
  fundingSources       FundingSource[]
  generatedReports     GeneratedReport[]
  grantConditions      GrantCondition[]
  savedReports         SavedReport[]
  shareLinks           ShareLink[]
}

model DonorProjectAccess {
  id                String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  donorOrgId        String?
  projectId         String
  tenantId          String
  grantedBy         String
  grantedAt         DateTime?          @default(now()) @db.Timestamp(6)
  revokedAt         DateTime?          @db.Timestamp(6)
  donorOrganisation DonorOrganisation? @relation(fields: [donorOrgId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([donorOrgId, projectId])
}

model DonorUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  donorId      String
  firstName    String
  lastName     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  donor        Donor    @relation(fields: [donorId], references: [id])

  @@index([donorId])
}

model Drawdown {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  investmentId      String           @db.Uuid
  requestDate       DateTime         @default(now()) @db.Timestamp(6)
  approvedDate      DateTime?        @db.Timestamp(6)
  approvedBy        String?          @db.Uuid
  amount            Decimal          @db.Decimal
  currency          String           @db.VarChar(10)
  purpose           String?
  status            String           @default("REQUESTED") @db.VarChar(20)
  sealId            String?          @db.Uuid
  utilisationAmount Decimal?         @default(0) @db.Decimal
  utilisationSealId String?          @db.Uuid
  createdAt         DateTime?        @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?        @default(now()) @db.Timestamp(6)
  requestedBy       String?          @db.Uuid
  rejectionReason   String?
  impactInvestment  ImpactInvestment @relation(fields: [investmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([investmentId], map: "idx_drawdown_investment")
}

model EngagementEvent {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String?
  eventType String
  metadata  Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([eventType])
  @@index([tenantId])
}

model ExchangeRate {
  id             String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  baseCurrency   String
  targetCurrency String
  rate           Float
  month          String
  source         String
  fetchedAt      DateTime? @default(now())
  lockedAt       DateTime?
  lockedByUserId String?
  sealTxHash     String?
  sealedAt       DateTime?
  createdAt      DateTime? @default(now())

  @@unique([baseCurrency, targetCurrency, month])
  @@index([month])
  @@index([baseCurrency, targetCurrency], map: "ExchangeRate_pair_idx")
}

model Expense {
  id                 String            @id @default(uuid())
  description        String
  amount             Float
  currency           String
  projectId          String
  fundingSourceId    String?
  tenantId           String
  createdAt          DateTime          @default(now())
  fundingAgreementId String?
  approvalStatus     String            @default("pending_review")
  category           String?
  expenseType        String?
  subCategory        String?
  budgetId           String?
  budgetLineId       String?
  receiptFileKey     String?
  receiptHash        String?
  receiptSealId      String?
  vendor             String?
  ocrAmount          Float?
  ocrVendor          String?
  ocrDate            String?
  amountMismatch     Boolean           @default(false)
  vendorMismatch     Boolean           @default(false)
  dateMismatch       Boolean           @default(false)
  mismatchNote       String?
  fraudRiskScore     Int?
  fraudRiskLevel     String?
  fraudSignals       Json?
  voided             Boolean           @default(false)
  voidedAt           DateTime?
  voidedBy           String?
  voidedReason       String?
  approvalNote       String?
  approvedAt         DateTime?
  approvedBy         String?
  expenditureType    String?           @default("OPEX") @db.VarChar(10)
  documents          Document[]
  budget             Budget?           @relation(fields: [budgetId], references: [id])
  budgetLine         BudgetLine?       @relation(fields: [budgetLineId], references: [id])
  fundingAgreement   FundingAgreement? @relation(fields: [fundingAgreementId], references: [id])
  fundingSource      FundingSource?    @relation(fields: [fundingSourceId], references: [id])
  project            Project           @relation(fields: [projectId], references: [id])
  tenant             Tenant            @relation(fields: [tenantId], references: [id])

  @@index([budgetId])
  @@index([budgetLineId])
  @@index([createdAt])
  @@index([expenseType])
  @@index([fundingAgreementId])
  @@index([fundingSourceId])
  @@index([projectId])
  @@index([tenantId])
}

model ExpenseChallenge {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expenseId     String    @db.Uuid
  projectId     String    @db.Uuid
  donorOrgId    String    @db.Uuid
  donorMemberId String    @db.Uuid
  note          String
  status        String    @default("OPEN") @db.VarChar(20)
  createdAt     DateTime? @default(now()) @db.Timestamp(6)
  updatedAt     DateTime? @default(now()) @db.Timestamp(6)

  @@index([donorOrgId], map: "idx_challenge_donor")
  @@index([expenseId], map: "idx_challenge_expense")
  @@index([projectId], map: "idx_challenge_project")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ExpenseChallengeResponse {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  challengeId           String    @db.Uuid
  respondedBy           String    @db.Uuid
  respondedByType       String    @db.VarChar(10)
  note                  String
  action                String?   @db.VarChar(20)
  resubmittedDocumentId String?   @db.Uuid
  createdAt             DateTime? @default(now()) @db.Timestamp(6)

  @@index([challengeId], map: "idx_challenge_response")
}

model FundingAgreement {
  id                  String                @id @default(uuid())
  donorId             String?
  tenantId            String
  title               String
  type                String                @default("GRANT")
  totalAmount         Float
  currency            String                @default("USD")
  startDate           DateTime?
  endDate             DateTime?
  interestRate        Float?
  repayable           Boolean               @default(false)
  status              String                @default("DRAFT")
  notes               String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  capexBudget         Float                 @default(0)
  grantFrom           DateTime?
  grantRef            String?
  grantTo             DateTime?
  grantorName         String?
  opexBudget          Float                 @default(0)
  restricted          Boolean               @default(false)
  sourceSubType       String?
  sourceType          String?
  budgetId            String?
  donorOrgId          String?
  funderName          String?               @db.VarChar(200)
  funderType          String?               @default("EXTERNAL") @db.VarChar(20)
  disbursementTranches DisbursementTranche[]
  expenses             Expense[]
  budget               Budget?               @relation(fields: [budgetId], references: [id])
  donor                Donor?                @relation(fields: [donorId], references: [id])
  donorOrganisation    DonorOrganisation?    @relation(fields: [donorOrgId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  grantConditions      GrantCondition[]
  projectFunding       ProjectFunding[]
  repayments           RepaymentSchedule[]

  @@index([budgetId])
  @@index([donorId])
  @@index([sourceType])
  @@index([status])
  @@index([tenantId])
  @@index([type])
}

model FundingSource {
  id                String             @id @default(uuid())
  name              String
  fundingType       String
  amount            Float
  currency          String
  projectId         String
  tenantId          String
  createdAt         DateTime           @default(now())
  donorOrgId        String?
  funderName        String?            @db.VarChar(200)
  funderType        String?            @default("EXTERNAL") @db.VarChar(20)
  expenses          Expense[]
  donorOrganisation DonorOrganisation? @relation(fields: [donorOrgId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project           Project            @relation(fields: [projectId], references: [id])
  tenant            Tenant             @relation(fields: [tenantId], references: [id])

  @@index([fundingType])
  @@index([projectId])
  @@index([tenantId])
}

model GeneratedReport {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String             @db.Uuid
  projectId         String?            @db.Uuid
  donorOrgId        String?
  reportType        String             @db.VarChar(30)
  name              String             @db.VarChar(200)
  dateRangeFrom     DateTime?          @db.Timestamp(6)
  dateRangeTo       DateTime?          @db.Timestamp(6)
  reportConfig      Json?
  fileKey           String?            @db.VarChar(500)
  fileUrl           String?            @db.VarChar(500)
  fileSizeBytes     Int?
  hash              String?            @db.VarChar(64)
  sealId            String?            @db.Uuid
  polygonTx         String?            @db.VarChar(100)
  generatedBy       String?            @db.Uuid
  generatedByType   String?            @db.VarChar(10)
  status            String?            @default("GENERATING") @db.VarChar(20)
  errorMessage      String?
  createdAt         DateTime?          @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?          @default(now()) @db.Timestamp(6)
  donorOrganisation DonorOrganisation? @relation(fields: [donorOrgId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reportShareLinks  ReportShareLink[]

  @@index([projectId], map: "idx_gen_report_project")
  @@index([tenantId], map: "idx_gen_report_tenant")
